        "3: Data Loading & Balancing"
      ],
      "metadata": {
        "id": "3PJ2eZRNWdu9"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def load_data(data_path, img_size=(128, 128)):\n",
        "    X, y = [], []\n",
        "    print(\"Searching for images in:\", data_path)\n",
        "\n",
        "    for root, dirs, files in os.walk(data_path):\n",
        "        folder_name = os.path.basename(root).lower()\n",
        "\n",
        "        for file in files:\n",
        "            if file.lower().endswith(('.png', '.jpg', '.jpeg')):\n",
        "                if 'yes' in folder_name or 'tumor' in folder_name:\n",
        "                    label = 1\n",
        "                elif 'no' in folder_name or 'normal' in folder_name:\n",
        "                    label = 0\n",
        "                else:\n",
        "                    continue\n",
        "\n",
        "                img_path = os.path.join(root, file)\n",
        "                img = cv2.imread(img_path)\n",
        "\n",
        "                if img is not None:\n",
        "                    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
        "                    img = cv2.resize(img, img_size)\n",
        "                    X.append(img)\n",
        "                    y.append(label)\n",
        "\n",
        "    print(f\"Successfully loaded {len(X)} images.\")\n",
        "    return np.array(X), np.array(y)\n",
        "\n",
        "def balance_dataset(X, y):\n",
        "    if len(X) == 0:\n",
        "        raise ValueError(\"Dataset is completely empty! Check your Zip file extraction.\")\n",
        "\n",
        "    X_tumor = X[y == 1]\n",
        "    y_tumor = y[y == 1]\n",
        "    X_no_tumor = X[y == 0]\n",
        "    y_no_tumor = y[y == 0]\n",
        "\n",
        "    print(f\"Before Balancing -> Tumor: {len(X_tumor)}, No Tumor: {len(X_no_tumor)}\")\n",
        "\n",
        "    if len(X_tumor) > len(X_no_tumor):\n",
        "        X_no_tumor_upsampled, y_no_tumor_upsampled = resample(\n",
        "            X_no_tumor, y_no_tumor, replace=True, n_samples=len(X_tumor), random_state=42\n",
        "        )\n",
        "        X_bal = np.vstack((X_tumor, X_no_tumor_upsampled))\n",
        "        y_bal = np.hstack((y_tumor, y_no_tumor_upsampled))\n",
        "    else:\n",
        "        X_tumor_upsampled, y_tumor_upsampled = resample(\n",
        "            X_tumor, y_tumor, replace=True, n_samples=len(X_no_tumor), random_state=42\n",
        "        )\n",
        "        X_bal = np.vstack((X_no_tumor, X_tumor_upsampled))\n",
        "        y_bal = np.hstack((y_no_tumor, y_tumor_upsampled))\n",
        "\n",
        "    print(f\"After Balancing -> Total Images: {len(X_bal)}\")\n",
        "    return X_bal, y_bal"
      ],
      "metadata": {
        "id": "9_Ps58_sWguF"
      },
      "execution_count": 5,
      "outputs": []
