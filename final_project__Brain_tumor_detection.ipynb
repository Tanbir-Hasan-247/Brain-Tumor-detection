        "                        textcoords=\"offset points\",\n",
        "                        ha='center', va='bottom', fontweight='bold', fontsize=9)\n",
        "\n",
        "    autolabel(rects1)\n",
        "    autolabel(rects2)\n",
        "    autolabel(rects3)\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()"
