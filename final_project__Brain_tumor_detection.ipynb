        "def evaluate_model_performance(y_true, y_pred, model_name=\"Model\"):\n",
        "    acc = accuracy_score(y_true, y_pred)\n",
        "    prec = precision_score(y_true, y_pred, zero_division=0)\n",
        "    rec = recall_score(y_true, y_pred, zero_division=0)\n",
        "    f1 = f1_score(y_true, y_pred, zero_division=0)\n",
        "\n",
        "    print(f\"\\n{'='*50}\")\n",
        "    print(f\"--- {model_name} Performance Metrics ---\")\n",
        "    print(f\"{'='*50}\")\n",
        "    print(f\"Accuracy  : {acc:.4f}\")\n",
        "    print(f\"Precision : {prec:.4f}\")\n",
        "    print(f\"Recall    : {rec:.4f}\")\n",
        "    print(f\"F1-Score  : {f1:.4f}\")\n",
        "    print(\"-\" * 50)\n",
        "\n",
        "    print(\"\\nClassification Report:\")\n",
        "    print(classification_report(y_true, y_pred, target_names=['No Tumor (0)', 'Tumor (1)'], zero_division=0))\n",
        "\n",
        "    cm = confusion_matrix(y_true, y_pred)\n",
        "\n",
        "    plt.figure(figsize=(5, 4))\n",
        "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n",
        "                xticklabels=['No Tumor', 'Tumor'],\n",
        "                yticklabels=['No Tumor', 'Tumor'])\n",
        "\n",
        "    plt.title(f'{model_name} - Confusion Matrix')\n",
        "    plt.ylabel('Actual Class')\n",
        "    plt.xlabel('Predicted Class')\n",
        "    plt.show()\n",
        "\n",
        "def plot_individual_training_curves(histories, model_name):\n",
        "    \"\"\"\n",
        "    Plots individual Training vs Validation Loss & Accuracy for a specific model.\n",
        "    \"\"\"\n",
        "    # Keras history object vs PyTorch dictionary handling\n",
        "    best_fold_idx = np.argmax([max(h.history['val_accuracy']) if hasattr(h, 'history') else max(h['val_accuracy']) for h in histories])\n",
        "    best_history = histories[best_fold_idx]\n",
        "\n",
        "    if hasattr(best_history, 'history'):\n",
        "        loss, val_loss = best_history.history['loss'], best_history.history['val_loss']\n",
        "        acc, val_acc = best_history.history['accuracy'], best_history.history['val_accuracy']\n",
        "    else:\n",
        "        loss, val_loss = best_history['loss'], best_history['val_loss']\n",
        "        acc, val_acc = best_history['accuracy'], best_history['val_accuracy']\n",
        "\n",
        "    plt.figure(figsize=(12, 4))\n",
        "\n",
        "    # Loss Plot\n",
        "    plt.subplot(1, 2, 1)\n",
        "    plt.plot(loss, label='Training Loss', color='blue', linewidth=2)\n",
        "    plt.plot(val_loss, label='Validation Loss', color='red', linewidth=2, linestyle='--')\n",
        "    plt.title(f'{model_name} Loss (Best Fold: {best_fold_idx + 1})')\n",
        "    plt.xlabel('Epochs')\n",
        "    plt.ylabel('Loss')\n",
        "    plt.legend()\n",
        "    plt.grid(True, alpha=0.3)\n",
        "\n",
        "    # Accuracy Plot\n",
        "    plt.subplot(1, 2, 2)\n",
        "    plt.plot(acc, label='Training Accuracy', color='green', linewidth=2)\n",
        "    plt.plot(val_acc, label='Validation Accuracy', color='orange', linewidth=2, linestyle='--')\n",
        "    plt.title(f'{model_name} Accuracy (Best Fold: {best_fold_idx + 1})')\n",
        "    plt.xlabel('Epochs')\n",
        "    plt.ylabel('Accuracy')\n",
        "    plt.legend()\n",
        "    plt.grid(True, alpha=0.3)\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "def plot_model_comparison_bars(cnn_metrics, vit_metrics, vgg_metrics):\n",
        "    \"\"\"\n",
        "    Plots a grouped bar chart comparing CNN, ViT, and VGG19 across 4 metrics.\n",
        "    \"\"\"\n",
        "    labels = ['Accuracy', 'Precision', 'Recall', 'F1-Score']\n",
        "    x = np.arange(len(labels))\n",
        "    width = 0.25  # Bar width adjusted for 3 models\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(12, 6))\n",
        "\n",
        "    rects1 = ax.bar(x - width, cnn_metrics, width, label='Custom CNN', color='#4C72B0')\n",
        "    rects2 = ax.bar(x, vit_metrics, width, label='Vision Transformer (ViT)', color='#DD8452')\n",
        "    rects3 = ax.bar(x + width, vgg_metrics, width, label='VGG19 Transfer Learning', color='#55A868')\n",
        "\n",
        "    ax.set_ylabel('Score (0.0 to 1.0)', fontsize=12)\n",
        "    ax.set_title('Performance Comparison: CNN vs ViT vs VGG19', fontsize=14, fontweight='bold')\n",
        "    ax.set_xticks(x)\n",
        "    ax.set_xticklabels(labels, fontsize=12)\n",
        "    ax.set_ylim(0, 1.15)\n",
        "    ax.legend(loc='lower right', fontsize=11)\n",
        "    ax.grid(axis='y', linestyle='--', alpha=0.7)\n",
        "\n",
        "    def autolabel(rects):\n",
        "        for rect in rects:\n",
        "            height = rect.get_height()\n",
        "            ax.annotate(f'{height:.3f}',\n",
        "                        xy=(rect.get_x() + rect.get_width() / 2, height),\n",
