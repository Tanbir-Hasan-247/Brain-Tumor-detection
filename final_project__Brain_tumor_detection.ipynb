    {
      "cell_type": "code",
      "source": [
        "def train_vit_model(vit_model, train_gen, val_gen, epochs=30, patience=10):\n",
        "    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "    vit_model = vit_model.to(device)\n",
        "    criterion = nn.BCELoss()\n",
        "    optimizer = optim.Adam(vit_model.parameters(), lr=1e-4)\n",
        "\n",
        "    best_val_loss = float('inf')\n",
        "    best_model_wts = copy.deepcopy(vit_model.state_dict())\n",
        "    epochs_no_improve = 0\n",
        "    history = {'loss': [], 'val_loss': [], 'accuracy': [], 'val_accuracy': []}\n",
        "\n",
        "    for epoch in range(epochs):\n",
        "        vit_model.train()\n",
        "        train_loss, train_correct, train_total = 0.0, 0, 0\n",
        "        for i in range(len(train_gen)):\n",
        "            batch_x, batch_y = train_gen[i]\n",
        "            inputs = torch.tensor(batch_x, dtype=torch.float32).permute(0, 3, 1, 2).to(device)\n",
        "            labels = torch.tensor(batch_y, dtype=torch.float32).unsqueeze(1).to(device)\n",
        "\n",
        "            optimizer.zero_grad()\n",
        "            outputs = vit_model(inputs)\n",
        "            loss = criterion(outputs, labels)\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "\n",
        "            train_loss += loss.item() * inputs.size(0)\n",
        "            preds = (outputs > 0.5).float()\n",
        "            train_correct += torch.sum(preds == labels.data).item()\n",
        "            train_total += labels.size(0)\n",
        "\n",
        "        epoch_train_loss = train_loss / train_total\n",
        "        epoch_train_acc = train_correct / train_total\n",
        "\n",
        "        vit_model.eval()\n",
        "        val_loss, val_correct, val_total = 0.0, 0, 0\n",
        "        with torch.no_grad():\n",
        "            for i in range(len(val_gen)):\n",
        "                batch_x, batch_y = val_gen[i]\n",
        "                inputs = torch.tensor(batch_x, dtype=torch.float32).permute(0, 3, 1, 2).to(device)\n",
        "                labels = torch.tensor(batch_y, dtype=torch.float32).unsqueeze(1).to(device)\n",
        "                outputs = vit_model(inputs)\n",
        "                loss = criterion(outputs, labels)\n",
        "                val_loss += loss.item() * inputs.size(0)\n",
        "                preds = (outputs > 0.5).float()\n",
        "                val_correct += torch.sum(preds == labels.data).item()\n",
        "                val_total += labels.size(0)\n",
        "\n",
        "        epoch_val_loss = val_loss / val_total\n",
        "        epoch_val_acc = val_correct / val_total\n",
        "\n",
        "        history['loss'].append(epoch_train_loss)\n",
        "        history['val_loss'].append(epoch_val_loss)\n",
        "        history['accuracy'].append(epoch_train_acc)\n",
        "        history['val_accuracy'].append(epoch_val_acc)\n",
        "\n",
        "        print(f\"ViT Epoch {epoch+1}/{epochs} - Loss: {epoch_train_loss:.4f}, Acc: {epoch_train_acc:.4f} | Val Loss: {epoch_val_loss:.4f}, Val Acc: {epoch_val_acc:.4f}\")\n",
        "\n",
        "        if epoch_val_loss < best_val_loss:\n",
        "            best_val_loss = epoch_val_loss\n",
        "            best_model_wts = copy.deepcopy(vit_model.state_dict())\n",
        "            epochs_no_improve = 0\n",
        "        else:\n",
        "            epochs_no_improve += 1\n",
        "            if epochs_no_improve >= patience:\n",
        "                print(\"Early stopping triggered for ViT.\")\n",
        "                break\n",
        "\n",
        "    vit_model.load_state_dict(best_model_wts)\n",
        "    return vit_model, history\n",
        "\n",
        "def train_evaluate_dual(X, y, n_splits=5):\n",
        "    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=42)\n",
        "    cnn_histories, vit_histories = [], []\n",
        "    cnn_all_y_true, cnn_all_y_pred = [], []\n",
        "    vit_all_y_true, vit_all_y_pred = [], []\n",
        "\n",
        "    X_normalized = X / 255.0\n",
        "    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "    fold = 1\n",
        "    for train_idx, val_idx in skf.split(X_normalized, y):\n",
        "        print(f\"\\n{'='*50}\\n--- Training Fold {fold}/{n_splits} ---\\n{'='*50}\")\n",
        "        X_train, X_val = X_normalized[train_idx], X_normalized[val_idx]\n",
        "        y_train, y_val = y[train_idx], y[val_idx]\n",
        "\n",
        "        train_gen = AlbumentationsGenerator(X_train, y_train, batch_size=16, transform=train_transform)\n",
        "        val_gen = AlbumentationsGenerator(X_val, y_val, batch_size=16, transform=val_transform)\n",
        "\n",
        "        # 1. Train CNN\n",
        "        print(\"\\n--> Starting CNN Training...\")\n",
        "        cnn_model = create_cnn_model(input_shape=(128, 128, 3))\n",
        "        weights = class_weight.compute_class_weight('balanced', classes=np.unique(y), y=y)\n",
        "        class_weights = dict(enumerate(weights))\n",
        "        early_stopping = EarlyStopping(monitor='val_loss', patience=12, restore_best_weights=True)\n",
        "        reduce_lr = ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=5, min_lr=1e-7)\n",
        "\n",
        "        cnn_history = cnn_model.fit(train_gen, validation_data=val_gen, epochs=100,\n",
        "                                    class_weight=class_weights, callbacks=[early_stopping, reduce_lr], verbose=0)\n",
        "        cnn_histories.append(cnn_history)\n",
        "\n",
        "        cnn_val_preds = (cnn_model.predict(X_val, verbose=0) > 0.5).astype(int).flatten()\n",
        "        cnn_all_y_true.extend(y_val)\n",
        "        cnn_all_y_pred.extend(cnn_val_preds)\n",
        "\n",
        "        # 2. Train ViT\n",
        "        print(\"\\n--> Starting ViT Training...\")\n",
        "        vit_model = BrainTumorViT(model_name='vit_small_patch16_224', pretrained=True)\n",
        "        best_vit, vit_history = train_vit_model(vit_model, train_gen, val_gen, epochs=30, patience=10)\n",
        "        vit_histories.append(vit_history)\n",
        "\n",
        "        best_vit.eval()\n",
        "        vit_preds_fold = []\n",
        "        with torch.no_grad():\n",
        "            for i in range(len(val_gen)):\n",
        "                batch_x, _ = val_gen[i]\n",
        "                inputs = torch.tensor(batch_x, dtype=torch.float32).permute(0, 3, 1, 2).to(device)\n",
        "                outputs = best_vit(inputs)\n",
        "                preds = (outputs > 0.5).int().cpu().numpy().flatten()\n",
        "                vit_preds_fold.extend(preds)\n",
        "\n",
        "        vit_all_y_true.extend(y_val)\n",
        "        vit_all_y_pred.extend(vit_preds_fold)\n",
        "        fold += 1\n",
        "\n",
        "    return (cnn_histories, cnn_all_y_true, cnn_all_y_pred), (vit_histories, vit_all_y_true, vit_all_y_pred)\n",
        "\n",
        "def train_evaluate_vgg19_only(X, y, n_splits=5):\n",
        "    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=42)\n",
        "    histories, all_y_true, all_y_pred = [], [], []\n",
        "\n",
        "    X_normalized = X / 255.0\n",
        "\n",
        "    fold = 1\n",
        "    for train_idx, val_idx in skf.split(X_normalized, y):\n",
        "        print(f\"\\n{'='*40}\\n--- Training VGG19 Fold {fold}/{n_splits} ---\\n{'='*40}\")\n",
        "\n",
        "        X_train, X_val = X_normalized[train_idx], X_normalized[val_idx]\n",
        "        y_train, y_val = y[train_idx], y[val_idx]\n",
        "\n",
        "        train_gen = AlbumentationsGenerator(X_train, y_train, batch_size=16, transform=train_transform)\n",
        "        val_gen = AlbumentationsGenerator(X_val, y_val, batch_size=16, transform=val_transform)\n",
        "\n",
        "        vgg19_model = create_vgg19_model(input_shape=(128, 128, 3))\n",
        "\n",
        "        weights = class_weight.compute_class_weight('balanced', classes=np.unique(y), y=y)\n",
        "        class_weights = dict(enumerate(weights))\n",
        "\n",
        "        early_stopping = EarlyStopping(monitor='val_loss', patience=12, restore_best_weights=True)\n",
        "        reduce_lr = ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=5, min_lr=1e-7)\n",
        "\n",
        "        history = vgg19_model.fit(\n",
        "            train_gen, validation_data=val_gen, epochs=100,\n",
        "            class_weight=class_weights, callbacks=[early_stopping, reduce_lr], verbose=2\n",
        "        )\n",
        "        histories.append(history)\n",
        "\n",
        "        print(f\"Evaluating VGG19 for Fold {fold}...\")\n",
        "        val_preds_prob = vgg19_model.predict(X_val)\n",
        "        val_preds = (val_preds_prob > 0.5).astype(int).flatten()\n",
        "\n",
        "        all_y_true.extend(y_val)\n",
        "        all_y_pred.extend(val_preds)\n",
        "        fold += 1\n",
        "\n",
        "    return histories, all_y_true, all_y_pred"
      ],
